# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/datatime

# Server port
PORT=5000

# OpenWeatherMap API key (free at https://openweathermap.org)
OPENWEATHER_API_KEY=your_openweather_api_key_here


# Frontend URL for CORS
CLIENT_URL=http://localhost:3000

# Optional Generative AI API Key (Groq) - Falls back to free open-source Pollinations if left empty
GROQ_API_KEY=your_groq_api_key_here

# Max snapshots per dataset (auto-cleanup deletes oldest beyond this)
MAX_SNAPSHOTS=200
